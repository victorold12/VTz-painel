rules_version = '2';

// VTz LLM — regras do Firestore.
// Cada usuário logado só pode ler e escrever o PRÓPRIO documento em users/{uid}.
// Ninguém acessa dados de outro usuário. Sem login = sem acesso ao banco.
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Qualquer outro caminho é negado por padrão.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
